DATA_PATH=dataset_V2.parquet
LOG_LEVEL=INFO
TARGET_COLUMN=LBL_NOK
TEST_SIZE=0.2
VAL_SIZE=0.2
RANDOM_STATE=42
FEATURE_SEQUENCE_LENGTH=512
LSTM_SEQUENCE_LENGTH=128
BATCH_SIZE=32
MAX_EPOCHS=25
PATIENCE=6
LEARNING_RATE=0.001
WEIGHT_DECAY=0.0001
HIDDEN_SIZE=64
LSTM_LAYERS=2
TABULAR_HIDDEN_DIM=128
FUSION_HIDDEN_DIM=128
DROPOUT=0.3
USE_ATTENTION=true
XGB_MODEL_PATH=models/xgboost_baseline.json
FUSION_CHECKPOINT_PATH=models/fusion_best.pt
FUSION_TORCHSCRIPT_PATH=models/fusion_model.ts
FUSION_ONNX_PATH=models/fusion_model.onnx
PREPROCESSOR_PATH=models/preprocessor_bundle.joblib
SPLIT_INDICES_PATH=data/processed/split_indices.json
METADATA_PATH=models/run_metadata.json
XGB_METRICS_PATH=models/xgboost_metrics.json
FUSION_METRICS_PATH=models/fusion_metrics.json
COMPARISON_METRICS_PATH=models/comparison_metrics.json
XGB_PREDICTIONS_PATH=models/xgboost_test_predictions.csv
FUSION_PREDICTIONS_PATH=models/fusion_test_predictions.csv
XGB_FEATURE_IMPORTANCE_PATH=plots/xgboost_feature_importance.png
XGB_CONFUSION_MATRIX_PATH=plots/xgboost_confusion_matrix.png
FUSION_CONFUSION_MATRIX_PATH=plots/fusion_confusion_matrix.png
TRAINING_CURVES_PATH=plots/fusion_training_curves.png
ROC_CURVE_PATH=plots/fusion_roc_curve.png
COMPARISON_PLOT_PATH=plots/model_comparison.png
METRICS_PLOT_PATH=plots/performance_summary.png
